# ─────────────────────────────────────────────
#  novaXchange — Catalog Service
#  Copy this file to .env and fill in the values
#  Never commit .env to git
# ─────────────────────────────────────────────

# ── App ───────────────────────────────────────
APP_ENV=development           # development | production
APP_PORT=8001
BASE_URL=http://localhost:8001 # https://novaxchange.xyz in production

# ── MongoDB ───────────────────────────────────
# Local (VPS or dev machine)
MONGO_URI=mongodb://localhost:27017/novaxchange
MONGO_DB_NAME=novaxchange

# ── Cloudflare R2  (Primary image store) ──────
# Get these from: Cloudflare Dashboard → R2 → Manage API tokens

R2_ACCOUNT_ID=47ba79a726959f21e3d7c0d7a76a14ff
R2_ACCESS_KEY_ID=https://47ba79a726959f21e3d7c0d7a76a14ff.r2.cloudflarestorage.com/novaxchange-products
R2_SECRET_ACCESS_KEY=c247ad5b4d282bd91e8724d8914e825981ee385630294c4421b1e23bab7abde4
R2_BUCKET_NAME=novaxchange-products

# Public URL for your bucket — enable in R2 bucket settings → Public access
R2_PUBLIC_URL=https://pub-5b965219b7644024b0894c7005c8c3e2.r2.dev

# ── Local disk  (VPS backup — currently commented out in storage.py) ──
# Uncomment the local write block in storage.py when you want dual-write
LOCAL_UPLOAD_DIR=/var/www/novaxchange/uploads/products
# In dev you can use a relative path:
# LOCAL_UPLOAD_DIR=./uploads/products

# ── Image storage mode ────────────────────────
# Controls which URL is returned to clients
# "r2"    → serve from R2 CDN (default)
# "local" → serve from VPS Nginx (failover)
IMAGE_SOURCE=r2

# ── JWT (shared with Auth service) ────────────
JWT_SECRET=change_this_to_a_long_random_string_min_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440  # 24 hours

# ── CORS ──────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,https://novaxchange.xyz,https://admin.novaxchange.xyz